# Copy to .env for local development. Never commit your real .env.

# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Comma-separated list of domains allowed to call the API.
# Not critical here since the frontend is served from the same origin,
# but keep it locked to your real domain once you have one.
ALLOWED_ORIGINS=*

PORT=3000
